# Browser-visible Site Manager configuration (never put secrets in VITE_*).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
VITE_ENABLE_DEV_AUTH=false

# Supabase Edge Function secrets. Set with `supabase secrets set`; do not expose to Vite.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
TOKEN_ENCRYPTION_KEY=base64url-encoded-32-byte-key
ENVIRONMENT=production
PLATFORM_BASE_URL=https://manager.example.com
TRADER_CORS_ORIGINS=https://optional-preview.example.net

# One shared repository, authenticated by a GitHub App.
GITHUB_APP_ID=github-app-id
GITHUB_APP_INSTALLATION_ID=github-app-installation-id
GITHUB_APP_PRIVATE_KEY=multiline-pem-private-key
GITHUB_REPO_OWNER=github-user-or-organisation
GITHUB_REPO_NAME=shared-sites-repository
GITHUB_REPO_BRANCH=main
GITHUB_SITES_CONFIG_ROOT=sites

# Central Netlify account. NETLIFY_GITHUB_INSTALLATION_ID belongs to Netlify's GitHub App.
NETLIFY_ACCESS_TOKEN=server-only-netlify-token
NETLIFY_ACCOUNT_SLUG=netlify-team-slug
NETLIFY_GITHUB_INSTALLATION_ID=netlify-github-installation-id
NETLIFY_WEBHOOK_SECRET=long-random-webhook-secret

# Existing optional commercial/email integrations.
LIPANA_SECRET_KEY=server-only-payment-key
LIPANA_WEBHOOK_SECRET=long-random-payment-webhook-secret
RESEND_API_KEY=server-only-email-key
